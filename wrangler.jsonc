{
    "compatibility_date": "2026-04-03",
    "compatibility_flags": ["global_fetch_strictly_public"],
    "name": "new-blog",
    "main": "@astrojs/cloudflare/entrypoints/server",
    "assets": {
        "directory": "./dist",
        "binding": "ASSETS",
    },
    "observability": {
        "enabled": true,
    },
}
