---
import { getSeries, getSeriesArticles } from '@data/articles';
import type { CollectionEntry } from 'astro:content';

interface Props {
    currentArticle: CollectionEntry<'blog'>;
}

const { currentArticle } = Astro.props;
const seriesId = currentArticle.data.series?.id;

let series;
let seriesArticles = [];
let currentIndex = -1;
let prevArticle = null;
let nextArticle = null;

if (seriesId) {
    series = await getSeries(seriesId);
    seriesArticles = await getSeriesArticles(seriesId);
    currentIndex = seriesArticles.findIndex(article => article.id === currentArticle.id);
    
    if (currentIndex > 0) {
        prevArticle = seriesArticles[currentIndex - 1];
    }
    
    if (currentIndex < seriesArticles.length - 1) {
        nextArticle = seriesArticles[currentIndex + 1];
    }
}
---

{series && (
    <div class="bg-bg-secondary rounded-lg p-6 my-8">
        <div class="mb-3">
            <h3 class="font-medium">Part of series: {series.data.title}</h3>
            <p class="text-sm text-font-color-muted">Article {currentIndex + 1} of {seriesArticles.length}</p>
        </div>
        
        <div class="h-1 bg-border-color rounded my-4">
            <div class="h-full bg-accent-color rounded" style={`width: ${((currentIndex + 1) / seriesArticles.length) * 100}%`}></div>
        </div>
        
        <div class="flex justify-between items-center flex-wrap gap-4 mt-4">
            {prevArticle && (
                <a href={`/articles/${prevArticle.id}`} class="text-accent-color hover:underline">
                    ← {prevArticle.data.title}
                </a>
            )}
            <a href={`/series/${seriesId}`} class="text-center px-4 py-2 border border-accent-color rounded text-accent-color">
                View all articles
            </a>
            {nextArticle && (
                <a href={`/articles/${nextArticle.id}`} class="text-accent-color hover:underline">
                    {nextArticle.data.title} →
                </a>
            )}
        </div>
    </div>
)}