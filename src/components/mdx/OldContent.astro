---
interface Props {
    publicationYear: number;
}

const yearsSinceRelease =
    new Date().getFullYear() - Astro.props.publicationYear;
---

<aside
    class="not-prose border-divider my-8 flex flex-col gap-2 border px-8 py-6"
>
    <p class="text-muted font-mono text-xs tracking-widest uppercase">
        Dated content
    </p>
    <p class="text-muted font-serif text-sm text-pretty">
        This article is {yearsSinceRelease} years old. Its content may no longer reflect
        the current state of the industry or my views.
    </p>
</aside>
