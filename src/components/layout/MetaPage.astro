---
import type { ArticleMeta, PageMeta } from "interface";

interface Props {
    pageMeta: PageMeta | ArticleMeta;
}

const { pageMeta } = Astro.props;
const isArticle = "article" in pageMeta;

const ogImageUrl = isArticle
    ? new URL(`/og/${pageMeta.article.id}.png`, Astro.site).toString()
    : "https://flavienbonvin.com/main_og.png";
const ogImageWidth = isArticle ? 1200 : 1920;
const ogImageHeight = isArticle ? 630 : 1080;
---

<title>{pageMeta.title}</title>
<meta name="description" content={pageMeta.description} />

<link rel="sitemap" href="/sitemap-index.xml" />

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width" />
<meta name="generator" content={Astro.generator} />

<meta property="og:site_name" content="Flavien Bonvin" />
<meta property="og:title" content={pageMeta.title} />
<meta property="og:description" content={pageMeta.description} />
<meta property="og:url" content={Astro.request.url} />

<link
    rel="alternate"
    type="application/rss+xml"
    title="Flavien Bonvin blog"
    href={new URL("rss.xml", Astro.site)}
/>

<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content={ogImageWidth.toString()} />
<meta property="og:image:height" content={ogImageHeight.toString()} />

{
    isArticle ? (
        <meta
            property="article:published_time"
            content={pageMeta.article.data.publicationDate.toISOString()}
        />
        <meta property="article:tag" content={pageMeta.article.data.tags.join(", ")} />
        <meta property="og:type" content="article" />
    ) : (
        <meta property="og:type" content="website" />
    )
}
