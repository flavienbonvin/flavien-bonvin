---
interface Props {
    href: string;
    target?: "_blank" | "_self";
    className?: string;
}

const { href, target, className } = Astro.props;
---

<a
    href={href}
    target={target}
    rel={target === "_blank" ? "noopener noreferrer" : undefined}
    class:list={[
        "transition-color inline-flex items-center font-mono text-xs tracking-widest uppercase duration-150",
        className,
    ]}><slot /></a
>
