---
interface Props {
    href: string;
    target?: "_blank" | "_self";
    className?: string;
}

const { href, target, className } = Astro.props;
---

<a
    href={href}
    target={target}
    rel={target === "_blank" ? "noopener noreferrer" : undefined}
    class:list={["underline transition-colors duration-150", className]}
    ><slot /></a
>
