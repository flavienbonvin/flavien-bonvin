---
interface Props {
    href: string;
    classes?: string;
    variant?: "button" | "inline";
}

const { variant = "button" } = Astro.props;
---

<a
    href={Astro.props.href}
    target="_blank"
    rel="noopener noreferrer"
    class:list={[
        variant === "button" &&
            "font-mono text-xs tracking-widest uppercase text-font-color border border-zinc-300 dark:border-zinc-700 px-4 py-2.5 text-center transition-colors duration-200 hover:border-zinc-500 dark:hover:border-zinc-500",
        variant === "inline" && "underline",
        Astro.props.classes,
    ]}><slot /></a
>
