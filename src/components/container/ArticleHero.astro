---
import type { CollectionEntry } from "astro:content";
import { ArticleType } from "interface";

interface Props {
    article: CollectionEntry<"articles">;
}

const { article } = Astro.props;
---

<div
    class:list={[
        "mb-8 flex h-32 items-end px-5 py-5 sm:h-48 sm:px-6 sm:py-6",
        article.data.type === ArticleType.DEV ? "bg-dev/90" : "bg-beyond/90",
    ]}
>
    <div class="flex flex-wrap gap-x-4 gap-y-1">
        {
            article.data.tags.map((tag) => (
                <span class="font-mono text-xs tracking-widest text-white/80 uppercase dark:text-white/70">
                    {tag}
                </span>
            ))
        }
    </div>
</div>
