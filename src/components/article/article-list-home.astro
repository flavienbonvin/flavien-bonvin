---
import type { CollectionEntry } from "astro:content";
import { ROUTES } from "const";
import { BlogType } from "content.config";
import ArticleCard from "./article-card.astro";

interface Props {
    articleType: BlogType;
    articles: CollectionEntry<"blog">[];
    classes?: string;
}

const isDev = Astro.props.articleType === BlogType.dev;
---

<section class="mb-16">
    <div
        class:list={[
            "flex items-center justify-between mb-4 pl-4 border-l-2",
            isDev ? "border-l-dev" : "border-l-beyond",
        ]}
    >
        <span
            class:list={[
                "font-mono text-xs tracking-widest uppercase",
                isDev ? "text-dev" : "text-beyond",
            ]}
        >
            {isDev ? "Dev" : "Beyond"}
        </span>
        <a
            href={isDev ? ROUTES.dev : ROUTES.beyond}
            class="font-serif text-sm italic text-font-color-muted hover:text-font-color transition-colors"
        >
            All articles
        </a>
    </div>
    <ul class="border-t border-zinc-200 dark:border-zinc-800">
        {Astro.props.articles.map((article) => <ArticleCard article={article} />)}
    </ul>
</section>
