---
import LinkGhost from "@ui/atoms/LinkGhost.astro";
---

<div class="border-divider mb-16 flex flex-col border-t pt-10 pb-4">
    <h2 class="mb-3 font-serif text-xl font-bold tracking-tight">
        Subscribe to the newsletter
    </h2>
    <p class="text-muted mb-6 font-serif text-sm italic">
        One article at a time. No campaigns, no filler.
    </p>
    <LinkGhost
        href="/newsletter"
        className="border-divider hover:border-focus w-fit border px-4 py-2.5 font-mono text-xs tracking-widest uppercase transition-colors"
    >
        Subscribe
    </LinkGhost>
</div>
