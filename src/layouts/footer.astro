---
import { CONFIG, URLS } from "const";

const year = new Date().getFullYear();
---

<div class="border-t border-zinc-200 dark:border-zinc-800 pt-6">
    <div class="flex items-center justify-between">
        <span class="font-serif text-xs text-font-color-muted">
            &copy; {year} {CONFIG.author}
        </span>
        <nav class="flex gap-6 sm:gap-8">
            <a
                href={URLS.twitter}
                target="_blank"
                rel="noopener noreferrer"
                class="font-mono text-xs tracking-widest uppercase text-font-color-muted hover:text-font-color transition-colors"
            >Twitter</a>
            <a
                href={`${Astro.site}rss.xml`}
                target="_blank"
                rel="noopener noreferrer"
                class="font-mono text-xs tracking-widest uppercase text-font-color-muted hover:text-font-color transition-colors"
            >RSS</a>
            <a
                href={URLS.blogGithub}
                target="_blank"
                rel="noopener noreferrer"
                class="font-mono text-xs tracking-widest uppercase text-font-color-muted hover:text-font-color transition-colors"
            >GitHub</a>
        </nav>
    </div>
</div>
