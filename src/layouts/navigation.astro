---
import Logo from "@components/atoms/logo.astro";
import { ROUTES } from "const";

const getIsActive = (href: string) => {
    return Astro.url.pathname.includes(href);
};
---

<nav class="w-full border-b border-zinc-200 dark:border-zinc-800">
    <div class="flex items-center justify-between py-5">
        <a href={ROUTES.home}>
            <Logo />
        </a>
        <ul class="flex items-center gap-8">
            <li>
                <a
                    href={ROUTES.dev}
                    class:list={[
                        "font-mono text-xs tracking-widest uppercase transition-colors",
                        getIsActive(ROUTES.dev)
                            ? "text-dev"
                            : "text-font-color-muted hover:text-font-color",
                    ]}>Dev</a
                >
            </li>
            <li>
                <a
                    href={ROUTES.beyond}
                    class:list={[
                        "font-mono text-xs tracking-widest uppercase transition-colors",
                        getIsActive(ROUTES.beyond)
                            ? "text-beyond"
                            : "text-font-color-muted hover:text-font-color",
                    ]}>Beyond</a
                >
            </li>
            <li>
                <a
                    href={ROUTES.about}
                    class:list={[
                        "font-mono text-xs tracking-widest uppercase transition-colors",
                        getIsActive(ROUTES.about)
                            ? "text-font-color"
                            : "text-font-color-muted hover:text-font-color",
                    ]}>About</a
                >
            </li>
        </ul>
    </div>
</nav>
