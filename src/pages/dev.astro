---
import Layout from "@ui/layout/Layout.astro";
import PageHeader from "@ui/shared/PageHeader.astro";
import ArticleList from "@ui/article/ArticleList.astro";
import type { PageMeta } from "interface";

import { getDevArticles } from "@data/articles";

const devArticles = await getDevArticles();

const pageMeta: PageMeta = {
    title: "Web dev | Flavien Bonvin",
    description: "Exploring web development. Join my journey.",
};
---

<Layout pageMeta={pageMeta}>
    <PageHeader title="Diving into web dev">
        {pageMeta.description}
    </PageHeader>
    <ArticleList articles={devArticles} />
</Layout>
