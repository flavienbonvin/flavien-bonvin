---
import { render } from "astro:content";
import { getAllArticles } from "@data/articles";
import Layout from "@ui/layout/Layout.astro";
import LayoutContent from "@ui/layout/LayoutContent.astro";
import ArticleHeader from "@ui/article/ArticleHeader.astro";
import type { ArticleMeta } from "interface";
import ArticleHero from "@ui/article/ArticleHero.astro";

export async function getStaticPaths() {
    const articles = await getAllArticles();
    return articles.map((article) => ({
        params: { slug: article.id },
        props: article,
    }));
}

const article = Astro.props;
const { Content } = await render(article);

const pageMeta: ArticleMeta = {
    title: article.data.title,
    description: article.data.description,
    article,
};
---

<Layout pageMeta={pageMeta}>
    <ArticleHeader article={article} />
    <ArticleHero article={article} />
    <LayoutContent type={article.data.type}>
        <Content />
    </LayoutContent>
</Layout>
