---
import ArticleListHome from "@components/article/article-list-home.astro";
import PageView from "@components/atoms/page-view.astro";
import NewsletterButton from "@components/newsletter/newsletter-button.astro";
import { getBeyondArticle, getDevArticles } from "@data/articles";
import PageLayout from "@layouts/page-layout.astro";
import SeoPage from "@layouts/seo-page.astro";
import { CONFIG } from "const";
import { BlogType } from "content.config";

const devPost = await getDevArticles(5);
const beyondPost = await getBeyondArticle(5);
---

<PageLayout>
    <SeoPage slot="head" title={CONFIG.author} description={CONFIG.description} />

    <ArticleListHome articleType={BlogType.dev} articles={devPost} />
    <ArticleListHome articleType={BlogType.beyond} articles={beyondPost} />
    <div class="border-t border-zinc-200 dark:border-zinc-800 pt-10">
        <NewsletterButton />
    </div>

    <PageView slug="home" />
</PageLayout>
