---
import ArticleList from "@components/article/article-list.astro";
import Divider from "@components/atoms/divider.astro";
import PageView from "@components/atoms/page-view.astro";
import NewsletterForm from "@components/newsletter/newsletter-form.astro";
import SeriesCard from "@components/series/series-card.astro";
import { getAllPublishedArticles, getAllSeries } from "@data/articles";
import PageLayout from "@layouts/page-layout.astro";
import SeoPage from "@layouts/seo-page.astro";
import { CONFIG } from "const";

// Get articles and series
const articles = await getAllPublishedArticles({ includeSeries: false });
const allSeries = await getAllSeries();
---

<PageLayout>
    <SeoPage slot="head" title={CONFIG.author} description={CONFIG.description} />
    
    {allSeries.length > 0 && (
        <div class="mb-12">
            <h2 class="text-2xl font-bold mb-6">Article Series</h2>
            <div class="space-y-6">
                {allSeries.map(series => (
                    <SeriesCard series={series} />
                ))}
            </div>
            <div class="mt-4">
                <a href="/series" class="text-accent-color hover:underline">View all series →</a>
            </div>
        </div>
    )}
    
    <div>
        <ArticleList
            title="Latest Insights: Coding & Beyond"
            articles={articles}
            pageDescription={CONFIG.homeDescription}
        />
    </div>
    
    <Divider classes="mb-10 mt-6" />
    <NewsletterForm />
</PageLayout>

<PageView slug="home" />
