---
import Layout from "@ui/layout/Layout.astro";
import { getBeyondArticles, getDevArticles } from "@data/articles";
import ArticleList from "@ui/container/ArticleList.astro";
import ArticleSection from "@ui/container/ArticleSection.astro";

import { ArticleType, type PageMeta } from "interface";

const devArticles = await getDevArticles();
const beyondArticles = await getBeyondArticles();

const pageMeta: PageMeta = {
    title: "Flavien Bonvin",
    description:
        "Flavien Bonvin personal blog where I speak about web development and beyond.",
};
---

<Layout pageMeta={pageMeta}>
    <ArticleSection type={ArticleType.DEV} />
    <ArticleList articles={devArticles} />
    <ArticleSection type={ArticleType.BEYOND} />
    <ArticleList articles={beyondArticles} />
</Layout>
