---
import Layout from "@ui/layout/Layout.astro";
import PageHeader from "@ui/container/PageHeader.astro";
import ArticleList from "@ui/container/ArticleList.astro";

import { getBeyondArticles } from "@data/articles";

const beyondArticles = await getBeyondArticles();
---

<Layout>
    <PageHeader title="Explorations of a developer">
        Life outside of coding. Discover my interest.
    </PageHeader>
    <ArticleList articles={beyondArticles} />
</Layout>
