---
import H1 from "@components/atoms/h1.astro";
import PageLayout from "@layouts/page-layout.astro";
import { ROUTES } from "const";
---

<PageLayout>
    <div class="py-20">
        <H1 classes="font-serif font-bold text-6xl sm:text-8xl tracking-tighter mb-4">404</H1>
        <p class="font-serif text-lg text-font-color-muted mb-8">
            This page wandered off. Even the duck can't find it.
        </p>
        <a
            href={ROUTES.home}
            class="font-mono text-xs tracking-widest uppercase text-font-color-muted hover:text-font-color transition-colors"
        >
            Back to home
        </a>
    </div>
</PageLayout>
