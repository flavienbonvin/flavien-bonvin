---
export const prerender = false;

import PageHeader from "@layouts/page-header.astro";
import PageLayout from "@layouts/page-layout.astro";
import SeoPage from "@layouts/seo-page.astro";
import { actions, isActionError } from "astro:actions";
import { CONFIG, URLS } from "const";

const result = Astro.getActionResult(actions.subscribeNewsletter);
const actionError = isActionError(result?.error) ? result.error.message : false;
const actionSuccess = result?.data?.success;
---

<PageLayout hideFooter>
    <SeoPage slot="head" title={CONFIG.author} description={CONFIG.description} />

    <PageHeader title="Subscribe to the newsletter">
        No spam, no advertisement, just the article that you can read right from your inbox!
    </PageHeader>

    <form
        method="POST"
        action={actions.subscribeNewsletter}
        class="flex flex-col gap-3 max-w-sm"
        id="newsletter-form"
    >
        <input
            required
            type="email"
            name="email"
            autocomplete="email"
            class="text-font-color bg-transparent border border-zinc-300 dark:border-zinc-700 w-full px-3 py-2.5 text-sm font-mono placeholder:text-font-color-muted focus:border-zinc-500 dark:focus:border-zinc-500 focus:outline-none transition-colors"
            placeholder="your@email.com"
        />
        <button
            class="w-full cursor-pointer font-mono text-xs tracking-widest uppercase border border-zinc-300 dark:border-zinc-700 px-4 py-2.5 hover:border-zinc-500 dark:hover:border-zinc-500 transition-colors"
            type="submit"
        >
            Subscribe
        </button>
    </form>

    {actionError && <p class="font-mono text-xs text-error mt-4">{actionError}</p>}
    {
        actionSuccess && (
            <p class="font-mono text-xs text-success mt-4">
                Thanks for subscribing! Please check your inbox to confirm your email.
            </p>
        )
    }

    <div class="mt-16">
        <p class="font-mono text-xs tracking-widest uppercase text-font-color-muted mb-6">
            Or follow me on socials
        </p>
        <nav class="flex gap-8">
            <a
                href={URLS.twitter}
                target="_blank"
                rel="noopener noreferrer"
                class="font-mono text-xs tracking-widest uppercase text-font-color-muted hover:text-font-color transition-colors"
            >Twitter</a>
            <a
                href={URLS.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="font-mono text-xs tracking-widest uppercase text-font-color-muted hover:text-font-color transition-colors"
            >LinkedIn</a>
        </nav>
    </div>
</PageLayout>
