---
import PageLayout from "@layouts/page-layout.astro";
import SeoPage from "@layouts/seo-page.astro";
import { ROUTES } from "const";
---

<PageLayout>
    <SeoPage
        title="Welcome to the club!"
        description="You have successfully subscribed to my newsletter."
    />
    <div class="py-20">
        <h1 class="font-serif font-bold text-4xl sm:text-5xl tracking-tighter mb-4">
            Welcome aboard
        </h1>
        <p class="font-serif text-sm text-font-color-muted italic mb-8">
            You're in. New articles will land straight in your inbox.
        </p>
        <a
            href={ROUTES.home}
            class="font-mono text-xs tracking-widest uppercase text-font-color-muted hover:text-font-color transition-colors"
        >
            Back to home
        </a>
    </div>
</PageLayout>
